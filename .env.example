# =============================================================================
# Kiln Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values.
#   cp .env.example .env

# Path to a local kiln.yaml to override the mock config in dev mode.
# When set, the mock GitHub client reads this file instead of its hardcoded config.
# OVERRIDE_KILN_CONFIG=./kiln.mock.yaml

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------

# Run in development mode (skips GitHub OAuth, uses mock workspace)
DEV_MODE=true

# Port the server listens on (default: 8080)
PORT=8080

# Log verbosity: debug, info, warn, error (default: info)
LOG_LEVEL=debug

# Secret used to sign session cookies. CHANGE THIS in production.
SESSION_SECRET=dev-secret-change-in-prod

# Comma-separated list of repos in owner/name format
REPOS=myorg/infra,myorg/platform

# Local directory used as a fake repo in dev mode
DEV_REPO_DIR=./backend/testdata/fake-infra

# -----------------------------------------------------------------------------
# GitHub OAuth & API (required when DEV_MODE=false)
# -----------------------------------------------------------------------------

# Create an OAuth App at https://github.com/settings/developers
# GITHUB_CLIENT_ID=xxx
# GITHUB_CLIENT_SECRET=xxx

# Personal access token with repo read access (used for cloning)
# GITHUB_TOKEN=ghp_xxx

# Only users in this GitHub org can access the app
# ALLOWED_ORG=your-org

# Public URL of the app (used for OAuth callback)
# BASE_URL=https://kiln.example.com

# -----------------------------------------------------------------------------
# AWS Credentials (passed through to Terraform / Pulumi)
# -----------------------------------------------------------------------------

# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=secret
# AWS_DEFAULT_REGION=us-east-1

# -----------------------------------------------------------------------------
# GCP Credentials (passed through to Terraform / Pulumi)
# -----------------------------------------------------------------------------

# Path to a service account JSON key file
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/credentials.json

# -----------------------------------------------------------------------------
# Pulumi (if using Pulumi engine)
# -----------------------------------------------------------------------------

# Pulumi access token for state management
# PULUMI_ACCESS_TOKEN=pul-xxx

# -----------------------------------------------------------------------------
# Workspace
# -----------------------------------------------------------------------------

# Directory where git clones are checked out for runs (default: /tmp/kiln)
# KILN_WORKSPACE_DIR=/tmp/kiln-workspace

